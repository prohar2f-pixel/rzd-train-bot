# Telegram Bot Token (получить в @BotFather)
TELEGRAM_TOKEN=your_bot_token_here

# Ваш Telegram Chat ID (напишите боту /start и посмотрите ID)
TELEGRAM_CHAT_ID=your_chat_id_here

# РЖД учётные данные (опционально для автобронирования)
RZD_LOGIN=your_email_here
RZD_PASSWORD=your_password_here

# Railway переменные (игнорируйте, автоматические)
NODE_ENV=production
